<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <title>Admin login</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <style>
    body {
      margin: 0;
      min-height: 100vh;
      display: grid;
      place-items: center;
      font-family: system-ui, sans-serif;
      background: #111;
      color: #eee;
    }

    form {
      width: min(420px, calc(100vw - 32px));
      padding: 24px;
      border: 1px solid #333;
      border-radius: 16px;
      background: #181818;
    }

    label {
      display: block;
      margin-bottom: 8px;
      color: #bbb;
    }

    input, button {
      width: 100%;
      box-sizing: border-box;
      font: inherit;
      border-radius: 10px;
      padding: 12px;
    }

    input {
      border: 1px solid #444;
      background: #0f0f0f;
      color: #fff;
    }

    button {
      margin-top: 16px;
      border: 0;
      cursor: pointer;
      background: #eee;
      color: #111;
      font-weight: 700;
    }

    .error {
      margin-bottom: 16px;
      padding: 12px;
      border-radius: 10px;
      background: #3a1010;
      color: #ffb3b3;
    }
  </style>
</head>
<body>
  <form method="post" action="/admin/login" autocomplete="off">
    <h1>Admin</h1>

    {% if error %}
      <div class="error">{{ error }}</div>
    {% endif %}

    <label for="password">Пароль</label>
    <input
      id="password"
      name="password"
      type="password"
      required
      autocomplete="current-password"
    >

    <button type="submit">Войти</button>
  </form>
</body>
</html>