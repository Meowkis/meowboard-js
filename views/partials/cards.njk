{% if cards.length == 0 %}
  <section class="empty-board" aria-labelledby="empty-board-title">
    <h2 id="empty-board-title">На доске пока пусто</h2>
    <p>Добавь первую карточку в админке, и она появится здесь.</p>
    <a href="/admin">Перейти в админку</a>
  </section>
{% else %}
  {% for card in cards %}
    {% include "partials/card.njk" %}
  {% endfor %}
{% endif %}
